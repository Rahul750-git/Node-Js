<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full text-white min-h-screen p-10 bg-zinc-900">
      <div class="flex w-full justify-end">
        <a
          href="/logout"
          class="bg-red-500 rounded-md px-3 py-2 text-sm inline-block"
          >Logout</a
        >
      </div>

      
      <h5 class="mb-5">edit your post.</h5>
      <form action="/update/<%= post._id %>" method="post">
        <textarea
          placeholder="What's your mind ?"
          name="content"
          class="w-1/3 p-3 resize-none rounded-md block outline-none bg-transparent border-2 border-zinc-800"
        ><%= post.content  %></textarea>
        <input
          type="submit"
          value="Update post"
          class="px-3 py-2 text-black bg-yellow-500 block mt-2 w-40 text-sm rounded-md active:scale-95"
        />
      </form>
    
    </div>
  </body>
</html>
