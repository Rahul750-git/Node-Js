<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full text-white min-h-screen p-10 bg-zinc-900">
      <div class="flex w-full justify-end">
        <a
          href="/logout"
          class="bg-red-500 rounded-md px-3 py-2 text-sm inline-block"
          >Logout</a
        >
      </div>

      <h1 class="text-3xl">
        <span class="font-light">Hello,</span> <%= user.name %>
      </h1>
      <h5 class="mb-5">you can create a new post.</h5>
      <form action="/post" method="post">
        <textarea
          placeholder="What's your mind ?"
          name="content"
          class="w-1/3 p-3 resize-none rounded-md block outline-none bg-transparent border-2 border-zinc-800"
        ></textarea>
        <input
          type="submit"
          value="Create new Post"
          class="px-3 py-2 bg-blue-500 block mt-2 w-40 text-sm rounded-md active:scale-95"
        />
      </form>
      <div class="posts mt-20">
        <h3 class="text-zinc-400">Your Posts.</h3>
        <div class="postcontainer mt-5">
             <% user.posts.reverse().forEach(function (post) { %>
              <div class="post w-1/3 p-5 mb-4 border-[1px] border-zinc-700 bg-zinc-800 rounded-md">
            <h4 class="text-blue-500 mb-2"><%= user.username %></h4>
            <p class="text-sm tracking-tighter">
              <%= post.content %>
            </p>
            <div class="btn flex gap-5 mt-5">
                <a href="/like"class="text-blue-500" >Like</a>
                <a href="/like"class="text-zinc-600 " >edit</a>
            </div>
          </div>
        <% });  %>
        </div>
      </div>
    </div>
  </body>
</html>
