<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <title>Document</title>
  <body>
    <div class="w-full text-white min-h-screen p-10 bg-zinc-900">
      <h1 class="text-3xl mb-5">Create Account</h1>
      <form action="/register" method="post">
        <input
          class="px-3 py-2 mb-3 rounded-md outline-none bg-transparent border-2 border-zinc-800"
          type="text"
          placeholder="name"
          name="name"
        />
        <input
          class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800"
          type="text"
          placeholder="username"
          name="username"
        />
        <input
          class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800"
          type="password"
          placeholder="password"
        />
        <input
          class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800"
          type="number"
          placeholder="age"
        />
        <input
          class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800"
          type="email"
          placeholder="email"
        />
        <input
          class="px-5 py-2 rounded-md outline-none bg-blue-500 active:scale-95"
          type="submit"
          value="Create Account"
        />
      </form>
    </div>
  </body>
</html>
