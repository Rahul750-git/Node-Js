<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full text-white min-h-screen p-10 bg-zinc-900">
      <h1 class="text-3xl mb-5">Upload File</h1>
      <form
        action="/upload"
        method="post"
        autocomplete="off"
        enctype="multipart/form-data"
      >
        <input type="file"  name="image"/>

        <input
          class="px-5 py-2 rounded-md outline-none bg-blue-500 active:scale-95"
          type="submit"
          value="Upload File"
        />
      </form>
    </div>
  </body>
</html>
