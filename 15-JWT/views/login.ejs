<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="bg-zinc-900 w-full h-screen text-white p-10">
      <h1 class="text-3xl mb-3">Login Page</h1>
      <form action="/login" method="post">
       
        <input
          class="px-3 py-2 rounded-md bg-transparent 
          border-2 border-zinc-800 outline-none"
          type="email"
          placeholder=" email"
          name="email"
        />
        <input
          class="px-3 py-2 rounded-md bg-transparent border-2
           border-zinc-800 outline-none"
          type="password"
          placeholder=" password"
          name="password"
        />
       
        <input
          class="px-5 py-2 rounded-md active:scale-95 bg-blue-500 border-2
          outline-none border-zinc-800"
          type="submit"
          value="Log in"
        />
      </form>
    </div>
  </body>
</html>