<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
  <div class="w-full h-screen bg-zinc-800 p-10 text-white">
    <div class="nav mb-10">
      <a href="/read" class="text-blue-500 hover:text-gray-400 ">Read Users</a>
    </div>
    <h1 class="text-3xl text-gray-400 tracking-tighter mb-4 ">Update User</h1>
   <form action="/update/<%= user._id %>" method="post">
    <input type="text" name="name" 
    placeholder="Enter your name"
    value="<%= user.name  %>" 
    class="bg-transparent border-2 border-zinc-800 py-2 rounded-lg outline-none px-5">
    
      <input type="text" name="email" 
    placeholder="Enter your email"
    value="<%= user.email  %>" 
    class="bg-transparent border-2 border-zinc-800 py-2 rounded-lg outline-none px-5">
    
      <input type="text" name="image" id=""
    placeholder="Image url"
    value="<%= user.image %>" 
    class="bg-transparent border-2 border-zinc-800 py-2 rounded-lg outline-none px-5">
     
    <input type="submit"
    value="Update User"
    class="bg-yellow-500 mt-5 rounded text-black px-3 py-2 hover:bg-yellow-300 active:scale-95 ml-5">
   </form>
  </div>
  </body>
</html>
