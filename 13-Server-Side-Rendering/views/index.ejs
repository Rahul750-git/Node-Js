<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
  <div class="w-full h-screen bg-zinc-800 p-10 text-white">
    <div class="nav mb-10">
      <a href="/read" class="text-blue-500 hover:text-gray-400 ">Read Users</a>
    </div>
    <h1 class="text-3xl text-gray-400 tracking-tighter mb-4 ">Create User</h1>
   <form action="/create" method="post">
    <input type="text" name="name" 
    placeholder="Enter your name" 
    class="bg-transparent border-2 border-zinc-800 py-2 rounded-lg outline-none px-5">
    
      <input type="text" name="email" id=""
    placeholder="Enter your email" 
    class="bg-transparent border-2 border-zinc-800 py-2 rounded-lg outline-none px-5">
    
      <input type="text" name="image" id=""
    placeholder="Image url" 
    class="bg-transparent border-2 border-zinc-800 py-2 rounded-lg outline-none px-5">
     
    <input type="submit"
    value="Create User"
    class="bg-blue-800 mt-5 rounded px-3 py-2 hover:bg-blue-600 active:scale-95 ml-5">
   </form>
  </div>
  </body>
</html>
