<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full h-screen bg-zinc-800 p-10 text-white ">
        <a class="text-blue-500 mb-10 hover:text-gray-400" href="/" >Back to Home</a>        
      <h1 class="text-3xl text-gray-400 tracking-tighter mb-4">All Users</h1>
      <div class="users flex gap-3 flex-wrap">
        <% if(users.length > 0) { %>
          <% users.forEach(function (user) { %>
           <div class="user w-72 p-4 bg-zinc-700 rounded-lg">
          <div class="w-full h-52 rounded-lg bg-zinc-600 overflow-hidden">
            <img 
            class="w-full h-full object-cover object-top "
            src="<%= user.image %>"   >
          </div>
          <h3 class="text-xl tracking-tighter mt-3"><%= user.name %></h3>
          <h5 class="text-zinc-500"><%= user.email %></h5>
          <div class="flex gap-3 mt-10">
            <a class="text-zinc-300" href="/edit/<%= user._id  %>">Edit User</a>
            <a class="text-red-500" href="/delete/<%= user._id  %>">Delete User</a>
          </div>
         </div>
        <% }) %>     

          <% } else { %>
                <h3 class="text-zinc-500">no users yet</h3>
           <% } %>
        
      </div>
    </div>
  </body>
</html>
