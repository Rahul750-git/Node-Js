<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="main w-full min-h-screen bg-zinc-900">
      <div class="form p-10 text-white">
        <form action="/create" method="post">
          <input
            type="text"
            class="block px-5 py-2 mt-2 w-full rounded-lg outline-none bg-zinc-800"
            placeholder="Title goes here"
            name="title"
          />
          <textarea
            class="block px-5 py-2 mt-2 w-full rounded-lg outline-none bg-zinc-800 resize-none"
            placeholder="Write your task details here..." name="details"
          ></textarea>
          <input
            type="submit"
            value="Create Task"
            class="mt-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-5 rounded"
          />
        </form>
      </div>
      <div class="tasks p-10 flex gap-5 flex-wrap">
        <% if(files.length > 0){ %>
        <% files.forEach(function (val) { %>
            <div class="task w-72  px-3 py-4 bg-zinc-800 rounded-md">
          <h1 class="text-white text-3xl tracking-tighter">
            <%= val %>
          </h1>
          <div class="flex w-full justify-between items-center mt-3 ">
              <a href="/files/ <%= val  %>" class="text-blue-500 underline inline-block "
            >Read More</a
          >
            <a  class="text-zinc-600 " href="/edit/<%= val  %>">edit filename</a>
        </div>
          </div>
         
       <% }) %>
        <% } else{ %>
      <h3 class="text-zinc-500 ms-9">no tasks yet.</h3>
       <% } %>
      </div>
     
    </div>
  </body>
</html>
