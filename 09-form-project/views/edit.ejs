<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="main w-full min-h-screen text-white bg-zinc-900 p-10">
      <a class="text-blue-500 inline-block mb-10" href="/">Go Back to Home</a>
   <form action="/edit" method="post">
            <input
              type="text"
              class="block px-5 py-2 mt-2 w-1/4 rounded-lg outline-none bg-zinc-800"
              placeholder="Previous name"
              name="previous "
              value="<%= filename  %>"
            />
            <input
              class="block px-5 py-2 mt-2 w-1/4 rounded-lg outline-none bg-zinc-800 resize-none"
              placeholder="New Name" name="New"
            >
            <input
              type="submit"
              value="Update Filename"
              class="mt-2 bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-2 px-5 rounded"
            />
          </form>
      </p>
    </div>
