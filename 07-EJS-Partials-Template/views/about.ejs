<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
     <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <div class="container">
      <div class="row mb-5">
        <div class="col bg-warning">
          <h1>EJS Template</h1>
        </div>
      </div>
      <div class="row mb-3">
        <div class="col-6">
           <h4><%= title %></h4>
         <table class="table" >
           <% items.forEach( item => {  %>
         <tr>
            <td><%= item.name %></td>
            <td><%= item.age %></td>
            <td><%= item.city %></td>  
         </tr>
         <%  }) %>
          </table>
        </div>
      <div class="row">
        <div class="col bg-info">Made by Rahul</div>
      </div>
    </div>
   

 
  </body>
</html>
